# Google Maps Distance Matrix API key
# https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Pushover credentials for sending notifications
# https://pushover.net/
PUSHOVER_TOKEN=your-pushover-app-token
PUSHOVER_USER=your-pushover-user-key

# SQLite database path (inside the container)
# For local dev, override with DB_PATH=./travel.db on the command line
DB_PATH=/app/data/travel.db
